# CGraph Environment Variables
# Copy to .env and fill in values for local development
# Production secrets are managed via Fly.io secrets and Vercel env vars

# ============================================
# Backend (Elixir/Phoenix)
# ============================================

# PostgreSQL connection (required)
DATABASE_URL=postgresql://cgraph:cgraph_dev_password@localhost:5432/cgraph_dev

# Secret key base for Phoenix sessions (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=generate-a-64-char-secret-with-mix-phx-gen-secret

# JWT signing secret (generate with: mix phx.gen.secret)
JWT_SECRET=generate-a-64-char-secret-for-jwt-signing

# Redis connection (required for PubSub, rate limiting, caching)
REDIS_URL=redis://localhost:6379

# Email service (Resend)
RESEND_API_KEY=re_your_resend_api_key

# Stripe billing (optional for dev)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# End-to-end encryption key (32 bytes, hex-encoded)
ENCRYPTION_KEY=generate-a-32-byte-hex-encoded-key

# Meilisearch (optional — falls back to PostgreSQL ILIKE)
# MEILISEARCH_URL=http://localhost:7700
# MEILISEARCH_API_KEY=your_meilisearch_master_key

# ============================================
# Frontend (Vite/React)
# ============================================

# API endpoint
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000/socket

# ============================================
# Deployment (CI/CD only)
# ============================================

# FLY_API_TOKEN=        # Fly.io deploy token
# CLOUDFLARE_API_TOKEN= # Cloudflare Pages deploy
# CLOUDFLARE_ACCOUNT_ID=
# EXPO_TOKEN=           # EAS Build token
# CODECOV_TOKEN=        # Coverage upload
