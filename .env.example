# CGraph Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ============================================
# REQUIRED - App will not start without these
# ============================================

# Generate with: mix phx.gen.secret (64+ chars)
SECRET_KEY_BASE=

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/cgraph_prod

# Message encryption key - generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Database pool configuration
DATABASE_POOL_SIZE=10

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate with: mix phx.gen.secret
# Note: JWT_SECRET is the canonical name used across all services
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# ============================================
# CLOUDFLARE R2 (File Storage)
# ============================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cgraph-files
R2_PUBLIC_URL=https://files.cgraph.io

# ============================================
# EMAIL CONFIGURATION (Resend)
# ============================================
FROM_EMAIL=noreply@cgraph.io
RESEND_API_KEY=re_xxxxxxxxxxxx

# ============================================
# ETHEREUM / WEB3 (Wallet Authentication)
# ============================================
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your-project-id
WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ============================================
# EXPO / MOBILE PUSH NOTIFICATIONS
# ============================================
EXPO_ACCESS_TOKEN=your-expo-access-token

# ============================================
# SENTRY (Error Tracking)
# ============================================
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ============================================
# APPLICATION SETTINGS
# ============================================
PHX_HOST=localhost
PHX_PORT=4000

# Frontend URLs (for CORS)
WEB_URL=http://localhost:3000
MOBILE_URL=exp://localhost:8081

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_WALLET_AUTH=true
ENABLE_E2EE=true
# Voice channels are marked as FUTURE - not yet implemented
ENABLE_VOICE_CHANNELS=false
