{
  "name": "@cgraph/core",
  "version": "0.8.6",
  "description": "Core domain logic and services for CGraph platform",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./domain/*": "./src/domain/*",
    "./services/*": "./src/services/*",
    "./utils/*": "./src/utils/*"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "dependencies": {
    "@cgraph/shared-types": "workspace:*",
    "@cgraph/utils": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  }
}
