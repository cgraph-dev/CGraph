{
  "name": "@cgraph/crypto",
  "private": true,
  "version": "0.9.31",
  "description": "Signal-grade E2EE for CGraph: Triple Ratchet (ECDH + ML-KEM-768), PQXDH, Double Ratchet, AES-256-GCM",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./aes": "./src/aes.ts",
    "./utils": "./src/utils.ts",
    "./errors": "./src/errors.ts",
    "./stores": "./src/stores.ts",
    "./types-portable": "./src/types-portable.ts",
    "./kem": "./src/kem.ts",
    "./x3dh": "./src/x3dh.ts",
    "./pqxdh": "./src/pqxdh.ts",
    "./doubleRatchet": "./src/doubleRatchet.ts",
    "./spqr": "./src/spqr.ts",
    "./tripleRatchet": "./src/tripleRatchet.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@noble/post-quantum": "^0.2.1"
  },
  "devDependencies": {
    "fast-check": "^3.23.2",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
