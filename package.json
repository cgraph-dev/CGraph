{
  "name": "cgraph",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "CGraph - Secure messaging platform with Signal Protocol-inspired E2EE and real-time collaboration",
  "author": "Burca Lucas",
  "homepage": "https://cgraph.org",
  "bugs": {
    "url": "https://github.com/cgraph-dev/CGraph/issues",
    "email": "hello@cgraph.org"
  },
  "license": "SEE LICENSE IN LICENSE",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "size": "turbo run build && size-limit",
    "size:check": "turbo run build && size-limit --json",
    "prepare": "husky",
    "web": "turbo run dev --filter=@cgraph/web",
    "mobile": "turbo run dev --filter=@cgraph/mobile",
    "backend:start": "cd apps/backend && mix phx.server",
    "backend:setup": "cd apps/backend && mix setup",
    "db:migrate": "cd apps/backend && mix ecto.migrate",
    "db:rollback": "cd apps/backend && mix ecto.rollback",
    "db:reset": "cd apps/backend && mix ecto.reset"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.39.2",
    "@size-limit/file": "^11.0.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^62.7.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "size-limit": "^11.0.0",
    "turbo": "^2.5.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.32.0"
  },
  "engines": {
    "node": ">=20.x",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "glob": "^11.0.0",
      "rimraf": "^6.0.0",
      "inflight": "npm:@pnpm/noop@1.0.0",
      "tar": ">=7.5.10",
      "esbuild": ">=0.25.0",
      "@babel/runtime": ">=7.26.10",
      "tmp": ">=0.2.4",
      "@tootallnate/once": ">=3.0.1"
    },
    "onlyBuiltDependencies": [
      "@next/swc",
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "bufferutil",
      "core-js",
      "esbuild",
      "msw",
      "msgpack",
      "utf-8-validate"
    ],
    "allowedDeprecatedVersions": {
      "glob": "*",
      "whatwg-encoding": "3.1.1"
    }
  },
  "packageManager": "pnpm@10.12.1",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
