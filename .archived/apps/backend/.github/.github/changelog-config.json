{
  "categories": [
    {
      "title": "## 🚀 Features",
      "labels": ["feature", "enhancement"]
    },
    {
      "title": "## 🐛 Bug Fixes",
      "labels": ["bug", "fix"]
    },
    {
      "title": "## 🔒 Security",
      "labels": ["security"]
    },
    {
      "title": "## 📚 Documentation",
      "labels": ["documentation", "docs"]
    },
    {
      "title": "## 🧪 Testing",
      "labels": ["test", "testing"]
    },
    {
      "title": "## 🏗️ Infrastructure",
      "labels": ["infrastructure", "ci", "devops"]
    },
    {
      "title": "## 💅 Styling",
      "labels": ["style", "ui"]
    },
    {
      "title": "## ⚡ Performance",
      "labels": ["performance"]
    },
    {
      "title": "## 📱 Mobile",
      "labels": ["mobile"]
    },
    {
      "title": "## 🔧 Maintenance",
      "labels": ["chore", "maintenance", "dependencies"]
    }
  ],
  "ignore_labels": ["skip-changelog"],
  "sort": {
    "order": "ASC",
    "on_property": "mergedAt"
  },
  "template": "#{{CHANGELOG}}\n\n### 📊 Statistics\n\n- PRs merged: #{{MERGED_COUNT}}\n- Contributors: #{{CONTRIBUTORS_COUNT}}\n\n---\n\n**Full Changelog**: https://github.com/#{{OWNER}}/#{{REPO}}/compare/#{{FROM_TAG}}...#{{TO_TAG}}",
  "pr_template": "- #{{TITLE}} (#{{NUMBER}}) @#{{AUTHOR}}",
  "empty_template": "No changes since last release.",
  "transformers": [],
  "max_pull_requests": 200,
  "max_back_track_time_days": 365
}
