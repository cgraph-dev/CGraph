# CGraph Observability Stack Environment Variables
# Copy this file to .env.observability and fill in real values.
#
# Usage:
#   cp .env.observability.example .env.observability
#   # Edit .env.observability with real secrets
#   docker compose -f docker-compose.observability.yml --env-file .env.observability up -d

# ─── Alertmanager Secrets ────────────────────────────────────────
# Slack incoming webhook URL for alert notifications
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# PagerDuty integration key for critical alerts
# Create at: https://support.pagerduty.com/docs/services-and-integrations
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key-here

# ─── Database Exporters ─────────────────────────────────────────
# PostgreSQL connection string for postgres-exporter
PG_DSN=postgresql://postgres:postgres@host.docker.internal:5432/cgraph_dev?sslmode=disable

# Redis address for redis-exporter
REDIS_ADDR=redis://host.docker.internal:6379
