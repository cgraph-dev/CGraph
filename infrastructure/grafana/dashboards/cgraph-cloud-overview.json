{
  "annotations": { "list": [] },
  "description": "CGraph production overview — Phoenix, BEAM, Ecto, WebSocket, Security",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum(rate(phoenix_endpoint_stop_duration_milliseconds_count{job=\"cgraph-phoenix\"}[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          }
        }
      }
    },
    {
      "title": "HTTP P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(phoenix_endpoint_stop_duration_milliseconds_bucket{job=\"cgraph-phoenix\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(phoenix_endpoint_stop_duration_milliseconds_bucket{job=\"cgraph-phoenix\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(phoenix_endpoint_stop_duration_milliseconds_bucket{job=\"cgraph-phoenix\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum(rate(phoenix_endpoint_stop_duration_milliseconds_count{job=\"cgraph-phoenix\", status=~\"5..\"}[5m])) / sum(rate(phoenix_endpoint_stop_duration_milliseconds_count{job=\"cgraph-phoenix\"}[5m])) * 100",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": [
            {
              "type": "special",
              "options": { "match": "nan", "result": { "text": "0%", "color": "green" } }
            }
          ]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "title": "WebSocket Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "cgraph_websocket_connections_active{job=\"cgraph-phoenix\"}",
          "legendFormat": "Active Connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "gradientMode": "scheme"
          },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "title": "Rate Limiter",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum(rate(cgraph_rate_limiter_check_total{job=\"cgraph-phoenix\", result=\"allowed\"}[5m]))",
          "legendFormat": "Allowed",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cgraph_rate_limiter_exceeded_total{job=\"cgraph-phoenix\"}[5m]))",
          "legendFormat": "Denied",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Denied" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Allowed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      }
    },
    {
      "title": "Auth Attempts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum(rate(cgraph_auth_login_success_total{job=\"cgraph-phoenix\"}[5m]))",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cgraph_auth_login_failure_total{job=\"cgraph-phoenix\"}[5m]))",
          "legendFormat": "Failure",
          "refId": "B"
        },
        {
          "expr": "sum(rate(cgraph_auth_account_locked_total{job=\"cgraph-phoenix\"}[5m]))",
          "legendFormat": "Lockouts",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Lockouts" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },
    {
      "title": "Ecto Query Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(cgraph_repo_query_total_time_milliseconds_bucket{job=\"cgraph-phoenix\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cgraph_repo_query_total_time_milliseconds_bucket{job=\"cgraph-phoenix\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(cgraph_repo_query_total_time_milliseconds_bucket{job=\"cgraph-phoenix\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "BEAM Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "vm_memory_total_bytes{job=\"cgraph-phoenix\"} / 1024 / 1024",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "vm_memory_processes_bytes{job=\"cgraph-phoenix\"} / 1024 / 1024",
          "legendFormat": "Processes",
          "refId": "B"
        },
        {
          "expr": "vm_memory_ets_bytes{job=\"cgraph-phoenix\"} / 1024 / 1024",
          "legendFormat": "ETS",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          }
        }
      }
    },
    {
      "title": "BEAM Run Queue Length",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "avg(vm_total_run_queue_lengths_total{job=\"cgraph-phoenix\"})",
          "legendFormat": "Run Queue",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 50,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Oban Jobs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum(rate(oban_job_stop_duration_milliseconds_count{job=\"cgraph-phoenix\", state=\"success\"}[5m]))",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(oban_job_exception_duration_milliseconds_count{job=\"cgraph-phoenix\"}[5m]))",
          "legendFormat": "Failed",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cgraph", "phoenix", "production"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CGraph — Production Overview",
  "uid": "cgraph-cloud-overview",
  "version": 1
}
