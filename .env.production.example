# =============================================================================
# CGraph Production Environment Configuration
# =============================================================================
# Copy to .env and fill in real values. NEVER commit actual secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16)
# -----------------------------------------------------------------------------
POSTGRES_USER=cgraph
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=cgraph_prod
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Backend (Elixir/Phoenix)
# -----------------------------------------------------------------------------
MIX_ENV=prod
PHX_HOST=cgraph.org
BACKEND_PORT=4000

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=GENERATE_WITH_MIX_PHX_GEN_SECRET

# Generate with: mix phx.gen.secret (can be different from SECRET_KEY_BASE)
JWT_SECRET=GENERATE_YOUR_JWT_SECRET

# Database pool size (start small, increase if needed)
POOL_SIZE=10

# -----------------------------------------------------------------------------
# Web Frontend
# -----------------------------------------------------------------------------
WEB_PORT=3000

# -----------------------------------------------------------------------------
# Optional: Email (Resend)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Optional: File Storage (Cloudflare R2)
# -----------------------------------------------------------------------------
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_BUCKET_NAME=cgraph-uploads

# -----------------------------------------------------------------------------
# Optional: OAuth Providers
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# APPLE_CLIENT_ID=your_apple_client_id
# APPLE_TEAM_ID=your_apple_team_id
# APPLE_KEY_ID=your_apple_key_id
# APPLE_PRIVATE_KEY=your_apple_private_key
# FACEBOOK_CLIENT_ID=your_facebook_client_id
# FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# -----------------------------------------------------------------------------
# Optional: Error Tracking (Sentry)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn

# -----------------------------------------------------------------------------
# Optional: CORS (comma-separated, defaults to cgraph.org variants)
# -----------------------------------------------------------------------------
# CORS_ORIGINS=https://cgraph.org,https://www.cgraph.org,https://app.cgraph.org

# -----------------------------------------------------------------------------
# Meilisearch (Full-Text Search)
# -----------------------------------------------------------------------------
# If not set, search falls back to PostgreSQL ILIKE queries.
# Options: Meilisearch Cloud, Railway, Render, self-hosted on Fly.io
MEILISEARCH_URL=https://your-meilisearch-instance.example.com
MEILISEARCH_API_KEY=your_production_master_key
