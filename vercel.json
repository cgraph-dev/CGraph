{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "pnpm turbo run build --filter=@cgraph/landing",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "apps/landing/dist",
  "redirects": [
    {
      "source": "/login",
      "destination": "https://web.cgraph.org/login",
      "statusCode": 308
    },
    {
      "source": "/register",
      "destination": "https://web.cgraph.org/register",
      "statusCode": 308
    },
    {
      "source": "/signup",
      "destination": "https://web.cgraph.org/register",
      "statusCode": 308
    },
    {
      "source": "/forgot-password",
      "destination": "https://web.cgraph.org/forgot-password",
      "statusCode": 308
    },
    {
      "source": "/reset-password",
      "destination": "https://web.cgraph.org/reset-password",
      "statusCode": 308
    },
    {
      "source": "/app/:path*",
      "destination": "https://web.cgraph.org/:path*",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://va.vercel-scripts.com https://vitals.vercel-insights.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true,
  "regions": ["fra1", "iad1", "sfo1"]
}
