# Vercel ignore file - only upload what's needed for web app build

# Ignore backend and mobile apps
apps/backend/
apps/mobile/

# Ignore documentation
/docs/
/docs-website/

# Ignore infrastructure
infrastructure/

# Ignore build artifacts (but NOT apps/web/dist - that's our output!)
node_modules/
**/node_modules/
**/_build/
**/deps/
**/.git/
**/.turbo/
**/coverage/
# Only ignore dist in non-web directories
packages/**/dist/
/docs-website/dist/
**/*.log
