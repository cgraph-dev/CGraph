{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "redirects": [
    {
      "source": "/login",
      "destination": "https://app.cgraph.org/login",
      "permanent": false
    },
    {
      "source": "/register",
      "destination": "https://app.cgraph.org/register",
      "permanent": false
    },
    {
      "source": "/signup",
      "destination": "https://app.cgraph.org/register",
      "permanent": false
    },
    {
      "source": "/forgot-password",
      "destination": "https://app.cgraph.org/forgot-password",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
