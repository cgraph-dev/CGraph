{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "pnpm turbo run build --filter=@cgraph/landing",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "apps/landing/dist",
  "regions": ["fra1", "iad1", "sfo1"],
  "redirects": [
    {
      "source": "/login",
      "destination": "https://app.cgraph.org/login",
      "statusCode": 308
    },
    {
      "source": "/register",
      "destination": "https://app.cgraph.org/register",
      "statusCode": 308
    },
    {
      "source": "/signup",
      "destination": "https://app.cgraph.org/register",
      "statusCode": 308
    },
    {
      "source": "/forgot-password",
      "destination": "https://app.cgraph.org/forgot-password",
      "statusCode": 308
    },
    {
      "source": "/reset-password",
      "destination": "https://app.cgraph.org/reset-password",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/app/:path*",
      "destination": "https://app.cgraph.org/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; connect-src 'self' https://app.cgraph.org https://cgraph-backend.fly.dev wss://cgraph-backend.fly.dev; font-src 'self' data: https://fonts.gstatic.com; frame-ancestors 'none'"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).woff2",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
