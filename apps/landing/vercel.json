{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "installCommand": "cd ../.. && npm install --legacy-peer-deps",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/login",
      "destination": "https://app.cgraph.org/login",
      "statusCode": 308
    },
    {
      "source": "/register",
      "destination": "https://app.cgraph.org/register",
      "statusCode": 308
    },
    {
      "source": "/signup",
      "destination": "https://app.cgraph.org/register",
      "statusCode": 308
    },
    {
      "source": "/forgot-password",
      "destination": "https://app.cgraph.org/forgot-password",
      "statusCode": 308
    },
    {
      "source": "/reset-password",
      "destination": "https://app.cgraph.org/reset-password",
      "statusCode": 308
    },
    {
      "source": "/app/:path*",
      "destination": "https://app.cgraph.org/:path*",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
