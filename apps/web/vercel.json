{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@cgraph/web",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "dist",
  "regions": ["fra1"],
  "redirects": [
    { "source": "/about", "destination": "https://cgraph.org/about", "statusCode": 308 },
    { "source": "/contact", "destination": "https://cgraph.org/contact", "statusCode": 308 },
    { "source": "/careers", "destination": "https://cgraph.org/careers", "statusCode": 308 },
    { "source": "/press", "destination": "https://cgraph.org/press", "statusCode": 308 },
    { "source": "/status", "destination": "https://cgraph.org/status", "statusCode": 308 },
    { "source": "/blog", "destination": "https://cgraph.org/blog", "statusCode": 308 },
    { "source": "/docs", "destination": "https://cgraph.org/docs", "statusCode": 308 },
    { "source": "/privacy", "destination": "https://cgraph.org/privacy", "statusCode": 308 },
    { "source": "/terms", "destination": "https://cgraph.org/terms", "statusCode": 308 },
    { "source": "/cookies", "destination": "https://cgraph.org/cookies", "statusCode": 308 },
    { "source": "/gdpr", "destination": "https://cgraph.org/gdpr", "statusCode": 308 },
    { "source": "/download", "destination": "https://cgraph.org/download", "statusCode": 308 },
    { "source": "/pricing", "destination": "https://cgraph.org/#pricing", "statusCode": 308 },
    { "source": "/features", "destination": "https://cgraph.org/#features", "statusCode": 308 },
    { "source": "/security", "destination": "https://cgraph.org/#security", "statusCode": 308 }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cgraph-backend.fly.dev/api/:path*"
    },
    {
      "source": "/socket/:path*",
      "destination": "https://cgraph-backend.fly.dev/socket/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(self), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; connect-src 'self' https://cgraph-backend.fly.dev wss://cgraph-backend.fly.dev https://*.ingest.sentry.io https://vitals.vercel-insights.com https://*.vercel-insights.com; font-src 'self' data: https://fonts.gstatic.com; frame-ancestors 'none'"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
