# =============================================================================
# CGraph Web Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control
# =============================================================================

# API Configuration
# For local development:
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
# For production (via nginx proxy):
# VITE_API_URL=/api
# VITE_WS_URL=wss://cgraph.org/socket

# App Configuration
VITE_APP_NAME=CGraph
VITE_APP_VERSION=1.0.0

# =============================================================================
# AI Configuration - PLACEHOLDER FOR FUTURE CLAUDE INTEGRATION
# =============================================================================
# AI features are not yet implemented. Reserved for future use.
# See: docs/architecture/AI_INTEGRATION.md
# Provider: Claude (Anthropic) - planned
VITE_AI_ENABLED=false
# Future AI features:
# VITE_AI_FORUM_MODERATION=false
# VITE_AI_CHAT_SUGGESTIONS=false
# VITE_AI_SMART_SEARCH=false
# VITE_AI_CONTENT_MODERATION=false

# Feature Flags (optional)
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_SENTRY=false

# Analytics (optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
