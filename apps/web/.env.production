# =============================================================================
# CGraph Web Frontend - Production Environment
# =============================================================================
# These values are baked into the build. Ensure they're correct before building.
# =============================================================================

# API Configuration
# IMPORTANT: For Vercel deployments, VITE_API_URL should be empty string
# This makes API calls use relative paths (e.g., /api/v1/auth/login)
# Vercel rewrites in vercel.json then proxy these to the backend
#
# For self-hosted nginx deployments, use: VITE_API_URL=/api
# For direct backend access, use: VITE_API_URL=https://your-backend.fly.dev
VITE_API_URL=

# WebSocket Configuration
# Empty string means use relative path (Vercel rewrites /socket/* to backend)
# For direct backend access, use: VITE_SOCKET_URL=wss://cgraph-backend.fly.dev/socket
VITE_SOCKET_URL=

# App Configuration
VITE_APP_NAME=CGraph
VITE_APP_VERSION=0.7.19

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
