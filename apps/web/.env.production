# =============================================================================
# CGraph Web Frontend - Production Environment
# =============================================================================
# These values are baked into the build. Ensure they're correct before building.
# =============================================================================

# API Configuration
# Direct backend access with CORS enabled for all cgraph*.vercel.app domains
VITE_API_URL=https://cgraph-backend.fly.dev

# WebSocket Configuration  
# Direct WebSocket to backend
VITE_WS_URL=wss://cgraph-backend.fly.dev/socket

# App Configuration
VITE_APP_NAME=CGraph
VITE_APP_VERSION=0.9.6

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
