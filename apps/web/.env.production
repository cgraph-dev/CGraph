# =============================================================================
# CGraph Web Frontend - Production Environment
# =============================================================================
# These values are baked into the build. Ensure they're correct before building.
# =============================================================================

# API Configuration
# Empty string = use relative paths that go through Vercel rewrites (recommended)
# This is the Discord-style approach: all API calls go through the same domain
# Benefits: No CORS issues, edge caching, single domain for security
VITE_API_URL=

# WebSocket Configuration  
# Direct WebSocket to backend (WebSockets can't be proxied through Vercel rewrites)
VITE_WS_URL=wss://cgraph-backend.fly.dev/socket

# App Configuration
VITE_APP_NAME=CGraph
VITE_APP_VERSION=0.9.5

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
