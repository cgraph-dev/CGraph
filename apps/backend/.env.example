# =============================================================================
# CGraph Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
MIX_ENV=dev
PORT=4000
PHX_HOST=localhost

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=your-secret-key-base-at-least-64-characters-long-generate-with-mix-phx-gen-secret

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=ecto://postgres:postgres@localhost/cgraph_dev
POOL_SIZE=10

# -----------------------------------------------------------------------------
# Redis (Session cache, rate limiting, pub/sub)
# -----------------------------------------------------------------------------
# Required for production. Optional in development (falls back to ETS).
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=20

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# Generate with: mix phx.gen.secret
# Note: JWT_SECRET is the canonical name used across all services
JWT_SECRET=your-jwt-secret-at-least-64-characters-long-generate-with-mix-phx-gen-secret

# Access token expires in 15 minutes (900 seconds)
JWT_ACCESS_TOKEN_TTL=900
# Refresh token expires in 7 days (604800 seconds)
JWT_REFRESH_TOKEN_TTL=604800

# -----------------------------------------------------------------------------
# Message Encryption (E2EE server-side key derivation)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
# CRITICAL: Required for production - used for encrypting sensitive data at rest
ENCRYPTION_KEY=your-encryption-key-generate-with-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# Email Service (Resend)
# -----------------------------------------------------------------------------
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# File Storage (Cloudflare R2 or S3-compatible)
# -----------------------------------------------------------------------------
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=cgraph-uploads
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CDN_URL=https://cdn.yourdomain.com

# -----------------------------------------------------------------------------
# Push Notifications (Expo)
# -----------------------------------------------------------------------------
EXPO_ACCESS_TOKEN=your-expo-access-token

# -----------------------------------------------------------------------------
# Web3 / Wallet Authentication (Optional)
# -----------------------------------------------------------------------------
# WALLET_CONNECT_PROJECT_ID=your-project-id

# -----------------------------------------------------------------------------
# Monitoring & Error Tracking (Optional)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn
# APPSIGNAL_PUSH_API_KEY=your-appsignal-key

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
