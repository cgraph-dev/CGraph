# Backend Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection URL
# Format: ecto://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=ecto://postgres:YOUR_PASSWORD@localhost:5432/cgraph_dev

# Database host (used for SSL SNI verification)
DATABASE_HOST=localhost

# Enable SSL for cloud databases (Supabase, RDS, etc.)
# Set to "true" for production
DATABASE_SSL=false

# SSL verification mode (leave empty for proper cert verification)
# Set to "none" ONLY for cloud providers with certificate issues
# WARNING: "none" disables certificate verification - use only when necessary
DATABASE_SSL_VERIFY=

# Connection pool size (adjust based on your needs)
POOL_SIZE=10

# =============================================================================
# SUPABASE (if using Supabase)
# =============================================================================

# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# PHOENIX / APPLICATION
# =============================================================================

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret

# Application host
PHX_HOST=localhost
PHX_PORT=4000

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT secret for token signing
# Generate with: openssl rand -base64 64
JWT_SECRET=generate_with_openssl_rand_base64_64

# Token expiry (in seconds)
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# =============================================================================
# ENCRYPTION
# =============================================================================

# E2EE server-side encryption key
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

# =============================================================================
# REDIS (optional - for caching and presence)
# =============================================================================

REDIS_URL=redis://localhost:6379

# =============================================================================
# FILE STORAGE
# =============================================================================

# Storage provider: local, s3, supabase
STORAGE_PROVIDER=local

# S3 configuration (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# =============================================================================
# OAUTH PROVIDERS (optional)
# =============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# =============================================================================
# PAYMENTS (optional)
# =============================================================================

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# =============================================================================
# EMAIL (optional)
# =============================================================================

# SMTP configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@cgraph.app

# =============================================================================
# MONITORING (optional)
# =============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Enable debug logging
DEBUG=false

# Disable rate limiting for development
DISABLE_RATE_LIMIT=false
