<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @title %></title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f5f5f5;
    }
    .container {
      max-width: 600px;
      margin: 20px auto;
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    .header {
      padding: 24px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }
    .header-title {
      font-size: 20px;
      font-weight: 600;
      margin: 0;
    }
    .content {
      padding: 24px;
    }
    .notification {
      padding: 16px;
      background: #f8f9fa;
      border-left: 4px solid #667eea;
      border-radius: 4px;
      margin-bottom: 16px;
    }
    .notification-type {
      font-size: 12px;
      text-transform: uppercase;
      color: #667eea;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .notification-message {
      font-size: 15px;
      color: #333;
      line-height: 1.5;
    }
    .notification-time {
      font-size: 13px;
      color: #888;
      margin-top: 8px;
    }
    .action-button {
      display: inline-block;
      margin-top: 16px;
      padding: 12px 24px;
      background: #667eea;
      color: white;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 500;
    }
    .footer {
      padding: 16px 24px;
      background: #f8f9fa;
      text-align: center;
      font-size: 13px;
      color: #666;
    }
    .unsubscribe {
      margin-top: 12px;
    }
    .unsubscribe a {
      color: #667eea;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1 class="header-title"><%= @title %></h1>
    </div>

    <div class="content">
      <div class="notification">
        <div class="notification-type"><%= @notification_type %></div>
        <div class="notification-message"><%= raw @message %></div>
        <div class="notification-time"><%= @timestamp %></div>
      </div>

      <%= if @action_url do %>
        <a href="<%= @action_url %>" class="action-button"><%= @action_text || "View Details" %></a>
      <% end %>
    </div>

    <div class="footer">
      <div>You're receiving this because you have notifications enabled.</div>
      <div class="unsubscribe">
        <a href="<%= @app_url %>/settings/notifications">Manage notification preferences</a>
      </div>
    </div>
  </div>
</body>
</html>
