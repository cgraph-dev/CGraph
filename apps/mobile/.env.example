# =============================================================================
# CGraph Mobile App Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control
# =============================================================================

# API Configuration
# For iOS Simulator: http://localhost:4000
# For Android Emulator: http://10.0.2.2:4000
# For physical device: http://YOUR_LOCAL_IP:4000
# For production: https://api.cgraph.org
API_URL=http://localhost:4000
WS_URL=ws://localhost:4000

# App Configuration
APP_NAME=CGraph
APP_VERSION=1.0.0

# =============================================================================
# AI Configuration - PLACEHOLDER FOR FUTURE CLAUDE INTEGRATION
# =============================================================================
# AI features are not yet implemented. Reserved for future use.
# See: docs/architecture/AI_INTEGRATION.md
# Provider: Claude (Anthropic) - planned
AI_ENABLED=false
# Future AI features:
# AI_FORUM_MODERATION=false
# AI_CHAT_SUGGESTIONS=false
# AI_SMART_SEARCH=false
# AI_CONTENT_MODERATION=false

# Expo Configuration
# Get from https://expo.dev
EXPO_PROJECT_ID=your-expo-project-id

# Feature Flags (optional)
# ENABLE_ANALYTICS=false
# ENABLE_SENTRY=false
